# Environment Configuration Example
# Copy this file to .env.local and fill in your values

# Environment mode (local, development, production)
REACT_APP_ENV=local

# API Configuration
REACT_APP_API_URL=http://localhost:3001

# AWS Cognito Configuration (leave empty for mock auth in local dev)
REACT_APP_USER_POOL_ID=
REACT_APP_USER_POOL_CLIENT_ID=
REACT_APP_AWS_REGION=sa-east-1

# WhatsApp Configuration
# Format: country code + area code + number (no spaces or special chars)
# Example: 5511999999999 for Brazil
REACT_APP_WHATSAPP_NUMBER=

# Email Configuration
REACT_APP_BARBERSHOP_EMAIL=

# reCAPTCHA Configuration (optional)
REACT_APP_RECAPTCHA_SITE_KEY=
